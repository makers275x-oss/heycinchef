"use client";

import React, { useEffect, useMemo, useRef, useState } from "react";
import RecipeCard, { Recipe } from "@/components/RecipeCard";

type Mode = "home" | "assistant" | "tarif" | "kokteyl" | "kombin";

// Tarif
type StageTarif = "upload" | "select" | "scanning" | "result" | "cook";
type MealType = "Yemek" | "Salata";

// Kokteyl
type StageCocktail = "upload" | "select" | "mixing" | "result";
type AlcoholLevel = "hafif" | "orta" | "sert";

type Cocktail = {
  title: string;
  why: string;
  steps: string[];
  glass?: string;
  garnish?: string;
  ice?: "none" | "cubes" | "crushed";
  alcoholLevel?: AlcoholLevel;
};

// Kombin (Quick only)
type Weather = "soğuk" | "ılık" | "sıcak";
type Place = "günlük" | "iş" | "date" | "parti";
type Style = "sade" | "cool" | "şık" | "komik";

type KombinOption = {
  title: string;
  why: string;
  items: string[];
  colorTip?: string;
};

function pick(arr: string[]) {
  return arr[Math.floor(Math.random() * arr.length)];
}

// --- Emoji temizleme (ses emojileri okumasın) ---
function stripEmojis(text: string) {
  return (text || "")
    .replace(/[\p{Extended_Pictographic}\u{1F1E6}-\u{1F1FF}]/gu, "")
    .replace(/\s{2,}/g, " ")
    .trim();
}

// --- Speech Queue (emoji temizliyor, kesmiyor) ---
let speaking = false;
const speechQueue: { text: string; rate: number }[] = [];

function flushSpeechQueue() {
  if (typeof window === "undefined") return;
  if (speaking) return;
  const next = speechQueue.shift();
  if (!next) return;

  try {
    const synth = window.speechSynthesis;
    const u = new SpeechSynthesisUtterance(next.text);
    u.lang = "tr-TR";
    u.rate = next.rate;

    speaking = true;
    u.onend = () => {
      speaking = false;
      flushSpeechQueue();
    };
    u.onerror = () => {
      speaking = false;
      flushSpeechQueue();
    };

    synth.speak(u);
  } catch {
    speaking = false;
  }
}

function sayTR(text: string, rate = 0.92) {
  if (typeof window === "undefined") return;
  const clean = stripEmojis(text);
  if (!clean) return;
  speechQueue.push({ text: clean, rate });
  flushSpeechQueue();
}

function stopSpeech() {
  if (typeof window === "undefined") return;
  try {
    window.speechSynthesis.cancel();
  } catch {}
  speaking = false;
  speechQueue.splice(0, speechQueue.length);
}

