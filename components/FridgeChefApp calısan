                  </button>
                </div>

                <div className="grid grid-cols-2 gap-3">
                  <div>
                    <label className="text-sm font-semibold">Süre (dk)</label>
                    <input
                      type="number"
                      min={5}
                      max={90}
                      value={timeLimit}
                      onChange={(e) => setTimeLimit(Number(e.target.value))}
                      className="mt-1 w-full rounded-2xl border px-3 py-2 text-sm"
                    />
                  </div>
                  <div>
                    <label className="text-sm font-semibold">Diyet</label>
                    <input
                      value={diet}
                      onChange={(e) => setDiet(e.target.value)}
                      className="mt-1 w-full rounded-2xl border px-3 py-2 text-sm"
                      placeholder="Serbest / Fit / Vejetaryen"
                    />
                  </div>
                </div>

                <div className="rounded-2xl border bg-gray-50 p-4">
                  <div className="flex items-center justify-between">
                    <div className="font-extrabold">Bulunan ürünler</div>
                    <div className="text-xs text-gray-500">
                      {selectedTarifItems.length}/{ingredientsTarif.length}
                    </div>
                  </div>

                  <div className="mt-3 grid grid-cols-2 gap-2">
                    {ingredientsTarif.map((i) => (
                      <label key={i} className="flex items-center gap-2 rounded-2xl bg-white p-2 border">
                        <input
                          type="checkbox"
                          checked={!!selectedTarif[i]}
                          onChange={(e) => setSelectedTarif((s) => ({ ...s, [i]: e.target.checked }))}
                        />
                        <span className="text-sm">{i}</span>
                      </label>
                    ))}
                  </div>
                </div>

                <button
                  onClick={generateTarif}
                  className="w-full rounded-2xl bg-black py-4 text-white font-extrabold"
                >
                  Seçilenlerle {mealType} yap
                </button>

                <button onClick={() => setStageTarif("upload")} className="w-full rounded-2xl bg-gray-100 py-3 font-extrabold">
                  Yeni foto
                </button>

                <button onClick={goHome} className="w-full rounded-2xl bg-gray-100 py-3 font-extrabold">
                  Ana menü
                </button>
              </div>
            )}

            {stageTarif === "result" && bestRecipe && (
              <RecipeCard
                recipe={bestRecipe}
                chefLine={chefTextTarif}
                onStart={() => {
                  sayTR("Tamam! Mutfak moduna geçiyoruz.");
                  setStageTarif("cook");
                }}
                onNewPhoto={() => setStageTarif("upload")}
              />
            )}

            {stageTarif === "cook" && bestRecipe && (
              <div className="rounded-[28px] border bg-white p-6 shadow-sm space-y-3">
                <div className="text-xl font-extrabold">{bestRecipe.title}</div>

                <div className="flex flex-wrap gap-2">
                  <Pill>{bestRecipe.timeMin ?? timeLimit} dk</Pill>
                  <Pill>{mealType}</Pill>
                </div>

                <button
                  onClick={() => {
                    sayTR("Adımları okuyorum.");
                    bestRecipe.steps.forEach((s, idx) => sayTR(`Adım ${idx + 1}. ${s}`, 0.9));
                  }}
                  className="w-full rounded-2xl bg-black py-4 text-white font-extrabold"
                >
                  Adımları sesli oku
                </button>

                <div className="space-y-2">
                  {bestRecipe.steps.map((s, idx) => (
                    <div key={idx} className="rounded-2xl border bg-white p-3">
                      <div className="text-xs text-gray-500">Adım {idx + 1}</div>
                      <div className="text-sm font-semibold">{s}</div>
                    </div>
                  ))}
                </div>

                <div className="grid grid-cols-2 gap-3">
                  <button onClick={() => setStageTarif("result")} className="rounded-2xl bg-gray-100 py-4 font-extrabold">
                    Geri
                  </button>
                  <button onClick={() => setStageTarif("upload")} className="rounded-2xl bg-black py-4 text-white font-extrabold">
                    Yeni foto
                  </button>
                </div>

                <button onClick={goHome} className="w-full rounded-2xl bg-gray-100 py-3 font-extrabold">
                  Ana menü
                </button>
              </div>
            )}
          </>
        )}

        {/* KOKTEYL */}
        {mode === "kokteyl" && (
          <>
            {stageCocktail === "upload" && (
              <div className="rounded-[28px] border bg-white p-6 shadow-sm space-y-4">
                <div className="rounded-[22px] bg-[#f3eadf] px-4 py-4">
                  <div className="text-xl font-extrabold">Kokteyl</div>
                  <div className="mt-1 text-sm text-gray-800">{chefTextCocktail}</div>
                </div>

                <div className="h-56 rounded-2xl bg-gray-200 flex items-center justify-center">
                  Şişe/bardak fotoğrafı yükle
                </div>

                <button
                  onClick={() => fileCocktailRef.current?.click()}
                  className="w-full rounded-2xl bg-black py-4 text-white font-extrabold"
                >
                  Fotoğraf seç
                </button>

                <input
                  ref={fileCocktailRef}
                  type="file"
                  accept="image/*"
                  className="hidden"
                  onChange={(e) => {
                    const f = e.target.files?.[0];
                    if (f) pickCocktailPhoto(f);
                  }}
                />

                <button onClick={goHome} className="w-full rounded-2xl bg-gray-100 py-3 font-extrabold">
                  Ana menü
                </button>
              </div>
            )}

            {stageCocktail === "select" && (
              <div className="rounded-[28px] border bg-white p-6 shadow-sm space-y-4">
                <div className="rounded-[22px] bg-[#f3eadf] px-4 py-4">
                  <div className="text-xl font-extrabold">Seç & Karıştır</div>
                  <div className="mt-1 text-sm text-gray-800">{chefTextCocktail}</div>
                </div>

                {previewCocktail ? (
                  <img src={previewCocktail} className="h-44 w-full rounded-2xl object-cover" alt="preview" />
                ) : null}

                <div className="grid grid-cols-3 gap-2">
                  {(["hafif", "orta", "sert"] as const).map((lvl) => (
                    <button
                      key={lvl}
                      onClick={() => setAlcoholLevel(lvl)}
                      className={`rounded-2xl py-2 text-sm font-extrabold ${
                        alcoholLevel === lvl ? "bg-black text-white" : "bg-gray-100 text-gray-800"
                      }`}
                    >
                      {lvl}
                    </button>
                  ))}
                </div>

                <div className="rounded-2xl border bg-gray-50 p-4">
                  <div className="flex items-center justify-between">
                    <div className="font-extrabold">Bulunan içecekler</div>
                    <div className="text-xs text-gray-500">
                      {selectedDrinkItems.length}/{drinksDetected.length}
                    </div>
                  </div>

                  <div className="mt-3 grid grid-cols-2 gap-2">
                    {drinksDetected.map((d) => (
                      <label key={d} className="flex items-center gap-2 rounded-2xl bg-white p-2 border">
                        <input
                          type="checkbox"
                          checked={!!selectedDrinks[d]}
                          onChange={(e) => setSelectedDrinks((s) => ({ ...s, [d]: e.target.checked }))}
                        />
                        <span className="text-sm">{d}</span>
                      </label>
                    ))}
                  </div>
                </div>

                <button onClick={generateCocktail} className="w-full rounded-2xl bg-black py-4 text-white font-extrabold">
                  Karışım öner
                </button>

                <button onClick={() => setStageCocktail("upload")} className="w-full rounded-2xl bg-gray-100 py-3 font-extrabold">
                  Yeni foto
                </button>

                <button onClick={goHome} className="w-full rounded-2xl bg-gray-100 py-3 font-extrabold">
                  Ana menü
                </button>
              </div>
            )}

            {stageCocktail === "mixing" && (
              <div className="rounded-[28px] border bg-white p-6 shadow-sm text-center space-y-3">
                <div className="rounded-[22px] bg-[#f3eadf] px-4 py-4 text-left">
                  <div className="text-xl font-extrabold">Karışıyor…</div>
                  <div className="mt-1 text-sm text-gray-800">{chefTextCocktail}</div>
                </div>

                {previewCocktail ? (
                  <img src={previewCocktail} className="h-52 w-full rounded-2xl object-cover" alt="preview" />
                ) : null}

                <div className="h-3 w-full overflow-hidden rounded-full bg-gray-200">
                  <div className="h-full w-3/4 animate-pulse bg-black" />
                </div>

                <button onClick={goHome} className="w-full rounded-2xl bg-gray-100 py-3 font-extrabold">
                  Ana menü
                </button>
              </div>
            )}

            {stageCocktail === "result" && cocktailResult && (
              <div className="rounded-[28px] border bg-white p-6 shadow-sm space-y-4">
                <div className="rounded-[22px] bg-[#f3eadf] px-4 py-4">
                  <div className="text-xl font-extrabold">{cocktailResult.title}</div>
                  <div className="mt-1 text-sm text-gray-800">{chefTextCocktail}</div>
                </div>

                <div className="rounded-2xl border p-4">
                  <div className="text-sm text-gray-600">{cocktailResult.why}</div>

                  <div className="mt-3 text-sm font-extrabold">Adımlar</div>
                  <ul className="mt-2 space-y-2 text-sm">
                    {cocktailResult.steps.map((s, idx) => (
                      <li key={idx} className="flex gap-2">
                        <span>•</span>
                        <span>{s}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <button
                  onClick={() => {
                    sayTR("Kokteyl adımlarını okuyorum.");
                    cocktailResult.steps.forEach((s, i) => sayTR(`Adım ${i + 1}. ${s}`, 0.9));
                  }}
                  className="w-full rounded-2xl bg-black py-4 text-white font-extrabold"
                >
                  Adımları sesli oku
                </button>

                <div className="grid grid-cols-2 gap-3">
                  <button onClick={() => setStageCocktail("select")} className="rounded-2xl bg-gray-100 py-4 font-extrabold">
                    Geri
                  </button>
                  <button onClick={() => setStageCocktail("upload")} className="rounded-2xl bg-black py-4 text-white font-extrabold">
                    Yeni foto
                  </button>
                </div>

                <button onClick={goHome} className="w-full rounded-2xl bg-gray-100 py-3 font-extrabold">
                  Ana menü
                </button>
              </div>
            )}
          </>
        )}

        {/* KOMBİN (Quick only) */}
        {mode === "kombin" && (
          <div className="rounded-[28px] border bg-white p-6 shadow-sm space-y-4">
            <div className="rounded-[22px] bg-[#f3eadf] p-4">
              <div className="text-xl font-extrabold">Bugün Ne Giysem</div>
              <div className="text-sm mt-1 text-gray-800">{chefTextKombin}</div>
            </div>

            <div className="rounded-2xl border bg-gray-50 p-4">
              <div className="font-extrabold">Hava</div>
              <div className="mt-2 flex gap-2">
                {(["soğuk", "ılık", "sıcak"] as const).map((w) => (
                  <button
                    key={w}
                    onClick={() => setWeather(w)}
                    className={`flex-1 rounded-2xl py-3 text-sm font-extrabold ${
                      weather === w ? "bg-black text-white" : "bg-white border"
                    }`}
                  >
                    {w}
                  </button>
                ))}
              </div>
            </div>

            <div className="rounded-2xl border bg-gray-50 p-4">
              <div className="font-extrabold">Nereye</div>
              <div className="mt-2 grid grid-cols-2 gap-2">
                {(["günlük", "iş", "date", "parti"] as const).map((p) => (
                  <button
                    key={p}
                    onClick={() => setPlace(p)}
                    className={`rounded-2xl py-3 text-sm font-extrabold ${
                      place === p ? "bg-black text-white" : "bg-white border"
                    }`}
                  >
                    {p}
                  </button>
                ))}
              </div>
            </div>

            <div className="rounded-2xl border bg-gray-50 p-4">
              <div className="font-extrabold">Stil</div>
              <div className="mt-2 grid grid-cols-2 gap-2">
                {(["sade", "cool", "şık", "komik"] as const).map((s) => (
                  <button
                    key={s}
                    onClick={() => setStyle(s)}
                    className={`rounded-2xl py-3 text-sm font-extrabold ${
                      style === s ? "bg-black text-white" : "bg-white border"
                    }`}
                  >
                    {s}
                  </button>
                ))}
              </div>
            </div>

            <button
              onClick={generateKombinQuick}
              disabled={kombinLoading}
              className="w-full rounded-2xl bg-black py-4 text-white font-extrabold disabled:opacity-60"
            >
              {kombinLoading ? "Cin düşünüyor…" : "Kombin öner"}
            </button>

            {quickKombinOptions && (
              <div className="space-y-3">
                {quickKombinOptions.map((o, idx) => (
                  <div key={idx} className="rounded-2xl border bg-white p-4">
                    <div className="text-lg font-extrabold">{o.title}</div>
                    <div className="mt-1 text-sm text-gray-600">{o.why}</div>
                    {o.colorTip ? (
                      <div className="mt-2 text-xs text-gray-500">Renk: {o.colorTip}</div>
                    ) : null}

                    <div className="mt-3 text-sm font-extrabold">Parçalar</div>
                    <ul className="mt-2 space-y-1 text-sm">
                      {(o.items || []).map((it, i) => (
                        <li key={i}>• {it}</li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            )}

            <button onClick={goHome} className="w-full rounded-2xl bg-gray-100 py-3 font-extrabold">
              Ana menü
            </button>
          </div>
        )}
      </div>
    </div>
  );
}