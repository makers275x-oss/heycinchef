      fd.append("image", f);
      fd.append("mode", "drinks");

      const r = await fetch("/api/vision", { method: "POST", body: fd });
      const data = await r.json().catch(() => ({}));

      if (!r.ok) {
        setChefTextCocktail(`Vision hata: ${data?.error ?? "Bilinmeyen hata"}`);
